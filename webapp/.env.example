OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PRIMARY_MODEL=gpt-5-mini
OPENAI_REVIEW_MODEL=gpt-5
OPENAI_REASONING_EFFORT=minimal

# 默认必须登录。纯本地不想登录、不配 Supabase 时设为 false
NEXT_PUBLIC_REQUIRE_LOGIN=true

# 仅开发：不配 Supabase 时用假登录测登录页（须 npm run dev；生产无效）
# NEXT_PUBLIC_DEV_MOCK_LOGIN=true

# Supabase（URL 必须是 https://xxx.supabase.co，不要用占位符）
NEXT_PUBLIC_SUPABASE_URL=https://你的项目.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的_anon_密钥
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 详见 AUTH.md（关闭邮箱确认、Redirect URLs 等）

# 分享填表邀请邮件（服务端直发到对方邮箱）
# 推荐与 Supabase 自定义 SMTP 使用同一套发信账号；不要提交真实密钥
# FORM_SHARE_SMTP_HOST=smtp.example.com
# FORM_SHARE_SMTP_PORT=465
# FORM_SHARE_SMTP_SECURE=true
# FORM_SHARE_SMTP_USER=mailer@example.com
# FORM_SHARE_SMTP_PASS=your_app_password_or_smtp_password
# FORM_SHARE_FROM_EMAIL=OrSight <mailer@example.com>

# 管理员后台根地址（无末尾斜杠）。生产示例：https://admin.你的域名.com
# 用户端登录页会显示「进入管理员登录」链到此地址的 /login；本地可填 http://localhost:3002
# NEXT_PUBLIC_ADMIN_APP_URL=https://admin.example.com
